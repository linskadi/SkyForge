# ==============================================================================
# SkyForge (天锻) 后端配置文件示例
# 复制此文件为 .env.dev 并填写实际配置
# 配置项格式：KEY=VALUE（等号两侧无空格）
# 修改后需重启后端服务生效
# ==============================================================================

# ============ 环境设置 ============
# 当前运行环境：dev（开发）/ prod（生产）
ENV=dev

# ============ LLM 配置 ============
# 是否使用真实 LLM（true=调用 LM Studio/OpenAI 兼容 API）
# 默认开启；LM Studio 不可用时自动降级为 Mock（关键词匹配+模板拼接）
USE_LLM=true

# 运行模式：mock / api / local。默认 mock，启动时不探测或预热模型。
SKYFORGE_LLM_MODE=mock

# 云端 Provider：deepseek / qwen / openai / anthropic / custom
SKYFORGE_LLM_PROVIDER=
LLM_API_KEY=
LLM_MODEL=

# 是否在后端启动时预热模型。比赛和低余额 API 建议保持 false。
SKYFORGE_LLM_WARMUP=false

# 本地 LLM 服务地址（OpenAI 兼容 API，支持 LM Studio / Ollama 等多 provider）
# 旧名 LMSTUDIO_BASE_URL 仍兼容一版本（会触发 DeprecationWarning）
LOCAL_LLM_BASE_URL=http://localhost:1234/v1

# ============ 系统配置 ============
# 日志级别：DEBUG/INFO/WARN/ERROR
LOG_LEVEL=INFO

# 调试模式：true（开发）/ false（生产）
DEBUG=true

# API调用失败重试次数
MAX_RETRIES=3

# ============ Redis 配置（可选） ============
# Redis连接地址（本地开发）
REDIS_URL=redis://localhost:6379/0

# ============ CORS 跨域配置 ============
CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ============ 服务地址配置 ============
# 后端服务访问地址
SERVER_HOST=http://localhost:8000

# ============ HIL 人机协作配置 ============
# 是否启用人机协作（true/false）
HIL_ENABLED=false

# HITL 人工审查（与真实 Hardware-in-the-Loop 独立）
HITL_ENABLED=false

# 审批超时时间（秒），超时后自动继续
HITL_TIMEOUT=300
