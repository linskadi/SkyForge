# ==============================================================================
# AirborneAI 后端配置文件示例
# 复制此文件为 .env.dev 并填写实际配置
# 配置项格式：KEY=VALUE（等号两侧无空格）
# 修改后需重启后端服务生效
# ==============================================================================

# ============ 环境设置 ============
# 当前运行环境：dev（开发）/ prod（生产）
ENV=dev

# ============ LLM 配置 ============
# 是否使用本地 LLM（true）或 Mock 模式（false）
USE_LLM=false

# LM Studio 本地服务器地址（OpenAI 兼容 API）
LMSTUDIO_BASE_URL=http://localhost:1234/v1

# ============ 系统配置 ============
# 日志级别：DEBUG/INFO/WARN/ERROR
LOG_LEVEL=INFO

# 调试模式：true（开发）/ false（生产）
DEBUG=true

# API调用失败重试次数
MAX_RETRIES=3

# ============ Redis 配置（可选） ============
# Redis连接地址（本地开发）
REDIS_URL=redis://localhost:6379/0

# ============ CORS 跨域配置 ============
CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ============ 服务地址配置 ============
# 后端服务访问地址
SERVER_HOST=http://localhost:8000

# ============ HIL 人机协作配置 ============
# 是否启用人机协作（true/false）
HIL_ENABLED=false

# 审批超时时间（秒），超时后自动继续
HIL_TIMEOUT=300
