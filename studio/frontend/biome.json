{
	"$schema": "https://biomejs.dev/schemas/2.5.4/schema.json",
	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": true
	},
	"files": {
		"ignoreUnknown": false,
		"includes": ["**", "!**/assets/styles/generate.css"]
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab"
	},
	"assist": { "actions": { "source": { "organizeImports": "on" } } },
	"linter": {
		"enabled": true,
		"rules": {
			"preset": "recommended",
			"style": {
				"useShorthandFunctionType": "warn",
				"noNonNullAssertion": "warn"
			},
			"complexity": {
				"noBannedTypes": "warn"
			},
			"suspicious": {
				"noImplicitAnyLet": "warn",
				"noAssignInExpressions": "warn"
			},
			"correctness": {
				"noPrecisionLoss": "warn"
			}
		}
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "double"
		}
	},
	"css": {
		"parser": {
			"tailwindDirectives": true
		}
	},
	"overrides": [
		{
			"includes": ["**/*.vue"],
			"linter": {
				"rules": {
					"style": {
						"useImportType": "off",
						"useVueMultiWordComponentNames": "off"
					},
					"correctness": {
						"noUnusedImports": "off",
						"noUnusedVariables": "off",
						"noVueDuplicateKeys": "off"
					}
				}
			}
		},
		{
			"includes": ["**/*.css"],
			"linter": {
				"rules": {
					"suspicious": {
						"noUnknownAtRules": "off"
					}
				}
			}
		}
	]
}
